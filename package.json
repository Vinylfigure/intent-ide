{
  "name": "intent-ide",
  "version": "0.1.0",
  "private": true,
  "description": "Voice-first AI document review tool — semantic commits instead of full-document regeneration. ProseMirror + Next.js + multi-agent debate (MADS) + GraphRAG cascade analysis.",
