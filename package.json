    "document-review",
    "prosemirror",
    "nextjs",
    "llm",
    "multi-agent",
    "graphrag",
    "voice",
    "human-in-the-loop"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
