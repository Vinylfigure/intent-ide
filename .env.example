# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Prisma (SQLite audit/compliance DB)
DATABASE_URL="file:./dev.db"

# --- FalkorDB (Graph Database) ---
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# --- Graphiti MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- Graphiti LLM (for entity extraction during episode ingestion) ---
# Provider: "openai" or "anthropic"
GRAPHITI_LLM_PROVIDER=anthropic
GRAPHITI_LLM_API_KEY=your-key-here
GRAPHITI_LLM_MODEL=claude-sonnet-4-6

# --- Frontend MCP Client ---
GRAPHITI_MCP_URL=http://localhost:8000/mcp/
