# Intent IDE - Environment Variables
# Copy this file to .env.local and fill in your values

# Default LLM provider: 'claude' or 'openai'
NEXT_PUBLIC_DEFAULT_PROVIDER=claude

# --- FalkorDB (start with: docker compose up -d) ---
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# --- Graphiti LLM (used for entity extraction, required) ---
GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_API_KEY=sk-your-key-here
GRAPHITI_LLM_MODEL=gpt-4o-mini

# --- Graphiti MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
GRAPHITI_MCP_URL=http://localhost:8000/mcp/
