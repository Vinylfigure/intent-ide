generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Annotation {
  id          String        @id @default(cuid())
  transcript  String
  intentType  String
  scopeStart  Int
  scopeEnd    Int
  createdAt   DateTime      @default(now())
  resolutions Resolution[]
}

model Resolution {
  id              String    @id @default(cuid())
  annotationId    String
  annotation      Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  semanticCommit  String
  reasoningChain  String
  uncertaintyMap  String
  approvalStatus  String    @default("PENDING")
  createdAt       DateTime  @default(now())
  auditLogs       AuditLog[]
}

/// EU AI Act Article 12 mandatory logging — 14-field Minimum Viable Audit Schema
/// Append-only: no update/delete operations permitted on audit records.
model AuditLog {
  id                  String     @id @default(cuid())
  resolutionId        String?
  resolution          Resolution? @relation(fields: [resolutionId], references: [id], onDelete: SetNull)
  timestampUTC        DateTime   @default(now())
  userId              String     @default("local")
  modelName           String     @default("")
  modelVersion        String
  promptVersion       String     @default("")
  promptHash          String
  queryClassification String     @default("")
  sourceDocuments     String     @default("[]")
  confidenceScore     Float?
  responseId          String     @default("")
  outputType          String     @default("RESOLUTION")
  regulatoryContext   String     @default("EU_AI_ACT")
  approvalStatus      String     @default("PENDING_REVIEW")
  dataRetentionDays   Int        @default(2555)
  graphNodesUsed      String     @default("[]")
  overrideOf          String?
  overrideReason      String?
}

/// Git-model document history — content-addressed snapshots in an append-only
/// linear chain (parent pointers). Restore creates a NEW commit; history is
/// never rewritten. EU AI Act Article 12 record-keeping surface.
/// Append-only: no update/delete operations permitted on history records.
model DocCommit {
  hash            String   @id
  documentId      String
  parentHash      String?
  kind            String   // 'import' | 'apply' | 'direct' | 'restore'
  message         String
  docJson         String
  blockIdsTouched String   @default("[]")
  annotationId    String?
  auditIds        String   @default("[]")
  actor           String   @default("human")
  modelVersion    String   @default("")
  createdAt       DateTime @default(now())

  @@index([documentId, createdAt])
}
